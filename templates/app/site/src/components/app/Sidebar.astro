---
import { siteConfig } from '../../config/site.config';

interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;
const base = import.meta.env.BASE_URL;

const navItems = [
  { key: 'dashboard', icon: '▦', ...siteConfig.nav.dashboard },
  { key: 'projects', icon: '◫', ...siteConfig.nav.projects },
  { key: 'settings', icon: '⚙', ...siteConfig.nav.settings },
];
---

<aside class="w-56 bg-surface-raised border-r border-edge flex flex-col shrink-0">
  <div class="p-4 border-b border-edge">
    <a href={base} class="font-bold text-heading text-lg hover:text-accent transition-colors">
      {siteConfig.brand}
    </a>
  </div>
  <nav class="flex-1 p-3 space-y-1">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-colors',
          activeNav === item.key
            ? 'bg-surface-strong text-heading font-medium'
            : 'text-muted hover:text-heading hover:bg-surface-strong/50',
        ]}
      >
        <span class="text-base">{item.icon}</span>
        {item.label}
      </a>
    ))}
  </nav>
</aside>
