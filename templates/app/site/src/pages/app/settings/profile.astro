---
import SettingsLayout from '../../../layouts/SettingsLayout.astro';
import FormField from '../../../components/app/FormField.astro';
---

<SettingsLayout title="Profile" activeSetting="profile">
  <h2 class="text-lg font-semibold text-heading mb-4">Profile</h2>
  <div class="bg-surface-raised border border-edge rounded-lg p-6">
    <form>
      <FormField label="Full name" name="name" value="Jane Doe" />
      <FormField label="Email" name="email" type="email" value="jane@example.com" />
      <FormField label="Job title" name="title" placeholder="e.g. Software Engineer" />
      <FormField label="Bio" name="bio" placeholder="Tell us about yourself" />
      <div class="flex justify-end mt-2">
        <button type="submit" class="px-4 py-2 bg-action text-action-text text-sm font-medium rounded-md hover:bg-action-hover transition-colors">
          Save changes
        </button>
      </div>
    </form>
  </div>
</SettingsLayout>
