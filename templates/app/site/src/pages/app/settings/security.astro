---
import SettingsLayout from '../../../layouts/SettingsLayout.astro';
import FormField from '../../../components/app/FormField.astro';
---

<SettingsLayout title="Security" activeSetting="security">
  <h2 class="text-lg font-semibold text-heading mb-4">Security</h2>

  <div class="bg-surface-raised border border-edge rounded-lg p-6 mb-6">
    <h3 class="text-base font-semibold text-heading mb-3">Change Password</h3>
    <form>
      <FormField label="Current password" name="current_password" type="password" />
      <FormField label="New password" name="new_password" type="password" help="At least 8 characters." />
      <FormField label="Confirm password" name="confirm_password" type="password" />
      <div class="flex justify-end mt-2">
        <button type="submit" class="px-4 py-2 bg-action text-action-text text-sm font-medium rounded-md hover:bg-action-hover transition-colors">
          Update password
        </button>
      </div>
    </form>
  </div>

  <div class="bg-surface-raised border border-edge rounded-lg p-6">
    <h3 class="text-base font-semibold text-heading mb-3">Two-Factor Authentication</h3>
    <p class="text-sm text-dim mb-3">Add an extra layer of security to your account.</p>
    <button class="px-4 py-2 bg-surface-strong text-heading text-sm font-medium rounded-md hover:bg-edge transition-colors">
      Enable 2FA
    </button>
  </div>
</SettingsLayout>
