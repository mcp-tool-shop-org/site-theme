---
import AppShell from '../../layouts/AppShell.astro';
import StatCards from '../../components/app/StatCards.astro';
import DataTable from '../../components/app/DataTable.astro';

const stats = [
  { label: 'Total Projects', value: '12', change: '+2 this month' },
  { label: 'Active Users', value: '48', change: '+5 this week' },
  { label: 'API Calls', value: '2.4k', change: '+12% vs last month' },
  { label: 'Uptime', value: '99.9%', change: 'Last 30 days' },
];

const columns = [
  { key: 'event', label: 'Event' },
  { key: 'user', label: 'User' },
  { key: 'time', label: 'Time', align: 'right' as const },
];

const rows = [
  { event: 'Deployed v2.1.0', user: 'alice@example.com', time: '2 min ago' },
  { event: 'Updated settings', user: 'bob@example.com', time: '15 min ago' },
  { event: 'Created project', user: 'carol@example.com', time: '1 hour ago' },
  { event: 'Invited team member', user: 'alice@example.com', time: '3 hours ago' },
  { event: 'Upgraded to Pro', user: 'dave@example.com', time: 'Yesterday' },
];
---

<AppShell title="Dashboard" activeNav="dashboard">
  <h1 class="text-2xl font-bold text-heading mb-6">Dashboard</h1>
  <StatCards stats={stats} />
  <h2 class="text-lg font-semibold text-heading mb-3">Recent Activity</h2>
  <DataTable columns={columns} rows={rows} />
</AppShell>
