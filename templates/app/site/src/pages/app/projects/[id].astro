---
import AppShell from '../../../layouts/AppShell.astro';
import Breadcrumbs from '../../../components/app/Breadcrumbs.astro';

export function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
  ];
}

const base = import.meta.env.BASE_URL;
const { id } = Astro.params;

const tabs = ['Overview', 'Settings', 'Deployments', 'Logs'];
---

<AppShell title={`Project ${id}`} activeNav="projects">
  <Breadcrumbs items={[
    { label: 'Projects', href: `${base}app/projects` },
    { label: `Project ${id}` },
  ]} />

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-heading">Project {id}</h1>
    <div class="flex gap-2">
      <button class="px-3 py-1.5 text-sm bg-surface-strong text-heading rounded-md hover:bg-edge transition-colors">
        Edit
      </button>
      <button class="px-3 py-1.5 text-sm bg-action text-action-text rounded-md hover:bg-action-hover transition-colors">
        Deploy
      </button>
    </div>
  </div>

  <div class="border-b border-edge mb-6">
    <nav class="flex gap-6">
      {tabs.map((tab, i) => (
        <button
          class:list={[
            'pb-3 text-sm font-medium border-b-2 transition-colors -mb-px',
            i === 0
              ? 'border-accent text-heading'
              : 'border-transparent text-dim hover:text-heading',
          ]}
        >
          {tab}
        </button>
      ))}
    </nav>
  </div>

  <div class="bg-surface-raised border border-edge rounded-lg p-6">
    <h2 class="text-lg font-semibold text-heading mb-2">Overview</h2>
    <p class="text-sm text-dim">
      Project details and configuration will appear here.
      Connect your backend to populate real data.
    </p>
  </div>
</AppShell>

