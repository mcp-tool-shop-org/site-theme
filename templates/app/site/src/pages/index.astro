---
/**
 * Root redirect — sends to /app if authenticated, /auth/sign-in otherwise.
 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
  </head>
  <body>
    <script>
      import { isAuthenticated } from '../lib/auth';
      const base = import.meta.env.BASE_URL;
      window.location.replace(isAuthenticated() ? `${base}app` : `${base}auth/sign-in`);
    </script>
  </body>
</html>
